# Copy this file to .env for local overrides.
# MySQL is enabled only when MYSQL_URL or MYSQL_HOST is present.
# MYSQL_URL=mysql://bus_game:password@127.0.0.1:3306/bus_game
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=bus_game
# MYSQL_PASSWORD=change_me
# MYSQL_DATABASE=bus_game
# MYSQL_CONNECTION_LIMIT=10

# Redis is enabled only when REDIS_URL or REDIS_HOST is present.
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_KEY_PREFIX=busgame
# REDIS_TRANSIENT_TTL_SECONDS=86400

PORT=3457
